---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import GameMenu from '../components/GameMenu.astro';
import PostCard from '../components/PostCard.astro';
import QuestCard from '../components/QuestCard.astro';
import StatusBar from '../components/StatusBar.astro';
import { byDateDesc } from '../utils/content';

const blog = byDateDesc(await getCollection('blog', ({ data }) => !data.draft));
const notes = byDateDesc(await getCollection('notes', ({ data }) => !data.draft));
const projects = byDateDesc(await getCollection('projects', ({ data }) => !data.draft));
const latest = byDateDesc([...blog, ...notes, ...projects]).slice(0, 3);
---

<BaseLayout>
  <section class="site-shell hero">
    <div class="pixel-frame save-menu">
      <p class="eyebrow">Save Point / Slot 01</p>
      <h1>Wynn's Save Point</h1>
      <p class="subtitle">
        Saving progress in code, ideas, and little experiments. 这里是我的技术小屋，
        记录编程项目、技术文章，以及一些关于构建、学习和生活的思考。
      </p>
      <GameMenu />
    </div>
    <StatusBar />
  </section>

  <section class="site-shell section-tight">
    <p class="eyebrow">Latest Logs</p>
    <h2 class="section-title">最近存档</h2>
    <div class="grid grid-3">
      {latest.map((entry) => <PostCard entry={entry} />)}
    </div>
  </section>

  <section class="site-shell section-tight">
    <div class="grid grid-2">
      <QuestCard
        title="构建个人网站"
        description="把长期写作、项目复盘和技术笔记收进一个安静、可维护的 Save Point。"
        value="72%"
        tags={['Astro', 'MDX', 'Cloudflare Workers']}
      />
      <section class="card">
        <div class="meta-line">
          <span>Inventory</span>
          <span>·</span>
          <span>Tools</span>
        </div>
        <h2>技术与兴趣</h2>
        <p class="muted">TypeScript / React / Python / AI / Tools / Writing</p>
        <ul class="tag-list">
          <li class="tag">TypeScript</li>
          <li class="tag">React</li>
          <li class="tag">Python</li>
          <li class="tag">AI</li>
          <li class="tag">Writing</li>
        </ul>
      </section>
    </div>
  </section>
</BaseLayout>
